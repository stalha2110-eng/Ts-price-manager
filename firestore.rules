rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidItem(data) {
      return data.keys().hasAll(['categoryId', 'quantity', 'buyingPrice', 'retailPrice']) &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.quantity is number && data.quantity >= 0 &&
             data.buyingPrice is number && data.buyingPrice >= 0 &&
             data.retailPrice is number && data.retailPrice >= 0;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'category', 'priority', 'status']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category in ['Stock', 'Payment', 'Customer', 'Supplier', 'Reminder', 'General'] &&
             data.priority in ['Urgent', 'Important', 'Completed', 'Info'] &&
             data.status in ['Active', 'Completed'];
    }

    function isValidSettings(data) {
      return true; // Simple settings validation
    }

    // Collections
    match /config/admin {
      allow read: if true; // Public access to config for app behavior
      allow write: if false; // Only manageable via Firebase Console or Admin SDK for now
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidSettings(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidSettings(incoming());

      match /items/{itemId} {
        allow list, get: if isValidId(userId); // Public read for client mode link
        allow create, update, delete: if isOwner(userId) && isValidId(itemId) && isValidItem(incoming());
      }

      match /notes/{noteId} {
        allow list, get: if isValidId(userId); // Public read for client mode link
        allow create, update, delete: if isOwner(userId) && isValidId(noteId) && isValidNote(incoming());
      }
    }
  }
}
